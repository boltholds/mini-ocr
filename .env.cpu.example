# Mini OCR CPU Docker environment
APP_PORT=8000
APP_MEMORY_LIMIT=12g
APP_SHM_SIZE=2g

POSTGRES_DB=ocr_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432
POSTGRES_MEMORY_LIMIT=2g
POSTGRES_SHM_SIZE=512m
POSTGRES_SHARED_BUFFERS=512MB
POSTGRES_WORK_MEM=16MB
POSTGRES_MAINTENANCE_WORK_MEM=256MB
POSTGRES_EFFECTIVE_CACHE_SIZE=1536MB
POSTGRES_MAX_CONNECTIONS=50

OCR_USE_GPU=false
OCR_LANG=ru
ENABLE_IMAGE_PREPROCESSING=false
ENABLE_AUTO_ROTATION=true

ENABLE_LLM=true
ENABLE_REGEX_FALLBACK=false
ENABLE_LANGGRAPH_WORKFLOW=true
ENABLE_AGENT_VALIDATION=true
ENABLE_OCR_CORRECTION_AGENT=true
ENABLE_RAG_VALIDATION=true
RAG_TOP_K=5

LLM_PROVIDER=ollama
# If Ollama runs on the host machine:
LLM_BASE_URL=http://host.docker.internal:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=qwen2.5:7b-instruct
PROMPT_VERSION=terms_abbrev_extractor_v9_clean_architecture
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=1
VALIDATION_AUTO_THRESHOLD=0.75
CORRECTION_AUTO_THRESHOLD=0.70

ENABLE_AGENT_TRACING=true
AGENT_LOG_LEVEL=INFO
AGENT_LOG_FILE=/data/logs/agents.log
