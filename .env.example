DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/ocr_db
STORAGE_DIR=data/storage

OCR_USE_GPU=true
OCR_LANG=ru
ENABLE_IMAGE_PREPROCESSING=false
ENABLE_AUTO_ROTATION=true

ENABLE_LLM=true
ENABLE_REGEX_FALLBACK=false

ENABLE_LANGGRAPH_WORKFLOW=true
ENABLE_AGENT_VALIDATION=true
ENABLE_OCR_CORRECTION_AGENT=true
ENABLE_RAG_VALIDATION=true
RAG_TOP_K=5

LLM_PROVIDER=ollama
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=qwen2.5:7b-instruct
PROMPT_VERSION=terms_abbrev_extractor_v9_clean_architecture
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=1
VALIDATION_AUTO_THRESHOLD=0.75
CORRECTION_AUTO_THRESHOLD=0.70

ENABLE_AGENT_TRACING=true
AGENT_LOG_LEVEL=INFO
AGENT_LOG_FILE=logs/agents.log
